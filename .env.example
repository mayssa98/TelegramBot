HP_BOT_TOKEN=replace_with_your_telegram_bot_token
HP_ADMIN_ID=replace_with_your_numeric_telegram_id
HP_BINANCE_PAY_ID=replace_with_your_binance_pay_id
HP_MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
HP_MONGODB_DB=heavenprem
HP_WEBHOOK_SECRET=replace_with_a_long_random_secret
HP_INVENTORY_KEY=replace_with_a_fernet_key
HP_DASHBOARD_PASSWORD=replace_with_a_long_random_password
HP_BINANCE_API_KEY=replace_with_a_read_only_api_key
HP_BINANCE_API_SECRET=replace_with_your_secret_key
HP_BINANCE_API_BASE=https://api.binance.com
HP_PAY_CURRENCY=USDT
# Development only: lets HP_ADMIN_ID verify an order with the fake TXID TEST-PAYMENT.
# Fake payments never call Binance, consume inventory, reward affiliates, or announce sales.
HP_TEST_PAYMENT_ENABLED=false
HP_AFFILIATE_QUALIFY_CENTS=1000
HP_AFFILIATE_FIVE_REWARD_CENTS=500
HP_AFFILIATE_TEN_REWARD_CENTS=200
HP_AFFILIATE_DAILY_CAP=10
